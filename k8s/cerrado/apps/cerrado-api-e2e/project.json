{
  "name": "cerrado-api-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["cerrado-api"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "dependsOn": ["cerrado-api:build", "cerrado-api:serve"],
      "options": {
        "jestConfig": "apps/cerrado-api-e2e/jest.config.cts",
        "passWithNoTests": true
      }
    }
  }
}
